# OAuth client credentials baked at build time (build.rs). Never commit; the
# committed template is .env.example. A slash-less pattern matches .env in any
# dir, so this covers both the repo root and src-tauri/.
.env
.env.local

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Decompiled Medal reference (browse-only; must never be committed)
.medal-decomp/

# Internal working docs / handoff notes (keep local, don't commit)
docs/

# Rust / Tauri
src-tauri/target/
src-tauri/gen/

# Bundled FFmpeg payload (fetched via scripts/fetch-ffmpeg.ps1).
# binding.rs is kept — it's the version-pinned prebuilt binding.
src-tauri/ffmpeg/bin/
src-tauri/ffmpeg/lib/
src-tauri/ffmpeg/include/
src-tauri/ffmpeg/LICENSE.txt

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Local planning artifacts
.mimir/
