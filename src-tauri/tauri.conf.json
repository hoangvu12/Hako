{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hako",
  "version": "1.3.0",
  "identifier": "com.hako.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Hako",
        "label": "main",
        "width": 1100,
        "height": 720,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "center": true,
        "visible": false
      },
      {
        "title": "Updating Hako",
        "label": "updater",
        "url": "updater.html",
        "width": 360,
        "height": 420,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "shadow": true,
        "center": true,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "visible": false,
        "width": 400,
        "height": 200
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$VIDEO/Hako/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hoangvu12/Hako/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJEMEU1Q0MxRjBCNDc0QUQKUldTdGRMVHd3VndPTFFJekppOFdnZmtPNmhiR2UycUNhV29GcTR2bVoyTlBKblpoVXh3L1pIcDcK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "vendor/obs-hook/*": "vendor/obs-hook/",
      "ffmpeg/bin/*.dll": "."
    }
  }
}
