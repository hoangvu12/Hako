# Template for src-tauri/.env — copy to `.env` (gitignored) and fill in your
# own OAuth client credentials. These get baked into the binary at build time
# (build.rs → option_env! → cloud::oauth). In CI they come from GitHub secrets
# of the same names instead, so this file is only for local development.
#
# Setup steps per provider: see docs / the cloud-phase2 handoff. Each provider's
# loopback redirect URIs (register where required) are:
#   http://127.0.0.1:51900  http://127.0.0.1:51901
#   http://127.0.0.1:51902  http://127.0.0.1:51903
#
# Leave a provider blank to disable its "Connect" button.

# Google Drive — "Desktop app" OAuth client (client id + secret).
HAKO_GOOGLE_CLIENT_ID=
HAKO_GOOGLE_CLIENT_SECRET=

# Dropbox — scoped app (App key = client id, App secret = client secret).
HAKO_DROPBOX_CLIENT_ID=
HAKO_DROPBOX_CLIENT_SECRET=

# Microsoft OneDrive — public desktop client (Application (client) ID; no secret).
HAKO_MICROSOFT_CLIENT_ID=
