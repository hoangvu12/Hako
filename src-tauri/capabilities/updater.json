{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "updater",
  "description": "Permissions for the Discord-style update splash window: check GitHub Releases, download + install a signed update, then relaunch.",
  "windows": ["updater"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default",
    "process:allow-restart"
  ]
}
